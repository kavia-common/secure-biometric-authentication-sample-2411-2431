<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed for sample API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="org.example.app.SecureSampleApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.SecureSample">

        <!--
          Preview-safe mode:
          Hosted preview/emulator environments may crash on startup due to keystore/biometric/network init.
          This flag lets the app disable fragile initialization at launch to prevent auto-close.
        -->
        <meta-data
            android:name="org.example.app.PREVIEW_SAFE_MODE"
            android:value="true" />

        <activity
            android:name="org.example.app.diagnostics.DiagnosticActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="org.example.app.MainActivity"
            android:exported="true"
            android:launchMode="singleTask" />

    </application>
</manifest>
